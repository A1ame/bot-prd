# Это ID чата, КУДА БУДУТ ПРИХОДИТЬ ВСЕ ПРЕДЛОЖЕНИЯ НА МОДЕРАЦИЮ
# Обычно это твой личный чат с ботом или отдельный канал для модерации
ADMIN_CHAT_ID=-1003437320456

# ID пользователей, которые имеют доступ к админ-панели
# Добавь сюда свой Telegram ID (и ID других админов через запятую)
ADMIN_USER_IDS=5187796471,1442060396

# Имя бота (username без @)
BOT_NAME=golem_gbot

# Остальные настройки (можно оставить как есть)
LOG_LEVEL=info
AUTO_MODERATION=true
RULES_MESSAGE_DELAY=5000
MAX_WARNINGS=3

# ───────────────────────────────────────
# ВКонтакте настройки
# ───────────────────────────────────────

# Токен группы ВК (управление → работа с API → создать ключ)
# Нужны права: wall, photos, docs


# ID группы ВК БЕЗ минуса (найти: vk.com/club123456789 → 123456789)
VK_GROUP_ID_1=237195393

# Интервал проверки новых постов в ВК (в миллисекундах, по умолчанию 30000 = 30 сек)
VK_POLLING_INTERVAL=30000

# Опционально: код подтверждения и секретный ключ для Callback API ВК
# (если используете webhook вместо polling — оставьте пустыми если не нужно)
